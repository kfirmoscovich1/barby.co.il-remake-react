rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isEditor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor'];
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isEditor();
      allow create: if request.auth.uid == userId;
      // Users can update own profile but cannot elevate their role or toggle isActive
      allow update: if isAdmin() ||
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isActive']));
      allow delete: if isAdmin();
    }

    match /shows/{showId} {
      // Public: only published, non-archived shows are visible
      allow read: if (resource.data.published == true && resource.data.archived == false) || isEditor();
      allow write: if isEditor();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /faq/{faqId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /media/{mediaId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /auditLogs/{logId} {
      allow read: if isEditor();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /giftCards/{giftCardId} {
      allow read: if isAuthenticated() &&
        (resource.data.purchaserId == request.auth.uid ||
         resource.data.recipientEmail == request.auth.token.email ||
         isEditor());
      // Validate: purchaser must be the authenticated user, amount must be in range
      allow create: if isAuthenticated() &&
        request.resource.data.purchaserId == request.auth.uid &&
        request.resource.data.amount >= 100 &&
        request.resource.data.amount <= 5000 &&
        request.resource.data.balance == request.resource.data.amount;
      allow update: if isEditor();
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isEditor());
      // Validate: order must belong to the authenticated user
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isEditor();
      allow delete: if false;
    }

    match /counters/{counterId} {
      allow read: if isAuthenticated();
      allow write: if isEditor();
    }
  }
}
